<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force canonical host even when requests arrive via alternate domains.
  RewriteCond %{HTTP_HOST} !^ddanalytics\.ca$ [NC]
  RewriteRule ^ https://ddanalytics.ca%{REQUEST_URI} [R=301,L]

  # Force HTTPS for every non-TLS request.
  # NOTE: Do not trust client-controlled forwarding headers here.
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://ddanalytics.ca%{REQUEST_URI} [R=301,L]

  # Allow existing files and directories to be served directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route all other requests to the SPA entrypoint.
  RewriteRule ^ index.html [L]
</IfModule>
