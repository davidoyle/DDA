<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force canonical HTTPS host.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.ddanalytics\.ca$ [NC]
  RewriteRule ^ https://ddanalytics.ca%{REQUEST_URI} [R=301,L]

  # Allow existing files and directories to be served directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route all other requests to the SPA entrypoint.
  RewriteRule ^ index.html [L]
</IfModule>
