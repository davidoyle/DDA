<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force canonical host even when requests arrive via alternate domains.
  RewriteCond %{HTTP_HOST} !^ddanalytics\.ca$ [NC]
  RewriteRule ^ https://ddanalytics.ca%{REQUEST_URI} [R=301,L]

  # Force HTTPS unless TLS is already handled upstream (e.g., proxy/CDN).
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://ddanalytics.ca%{REQUEST_URI} [R=301,L]

  # Allow existing files and directories to be served directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route all other requests to the SPA entrypoint.
  RewriteRule ^ index.html [L]
</IfModule>
